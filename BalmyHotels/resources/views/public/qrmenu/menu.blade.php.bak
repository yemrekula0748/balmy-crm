<!DOCTYPE html>
<html lang="{{ $lang }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ $menu->getTitle($lang) }}</title>
    <meta name="theme-color" content="{{ $menu->theme_color ?? '#1a1a2e' }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --accent: {{ $menu->theme_color ?? '#c19b77' }};
            --bg: #0d0d0d;
            --surface: #181818;
            --surface2: #222;
            --border: rgba(255,255,255,.08);
            --text: #f0ece6;
            --muted: #888;
        }
        html { scroll-behavior: smooth; }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            min-height: 100dvh;
            padding-bottom: 80px;
        }

        /* HEADER */
        .menu-header {
            position: relative;
            min-height: 220px;
            display: flex;
            align-items: flex-end;
            padding: 1.5rem;
            overflow: hidden;
        }
        .header-bg {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center;
            @if($menu->cover_image)
            background-image: url('{{ asset('storage/'.$menu->cover_image) }}');
            @else
            background: linear-gradient(135deg, #1a1a2e, {{ $menu->theme_color ?? '#c19b77' }}33);
            @endif
            filter: brightness(.4);
        }
        .header-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(13,13,13,.95) 0%, transparent 60%);
        }
        .header-content {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            gap: 1rem;
            width: 100%;
        }
        .header-logo {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent);
            flex-shrink: 0;
        }
        .header-logo-placeholder {
            width: 60px; height: 60px;
            border-radius: 50%;
            background: var(--accent);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem; font-weight: 700; color: #fff;
            flex-shrink: 0;
        }
        .header-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
        }
        .header-sub {
            font-size: .75rem;
            color: var(--muted);
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        /* DİL SEÇİCİ */
        .lang-switcher {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 100;
            display: flex;
            gap: .4rem;
            flex-wrap: wrap;
            justify-content: flex-end;
            max-width: 180px;
        }
        .lang-switcher a {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: .3rem .7rem;
            border-radius: 50px;
            font-size: .72rem;
            font-weight: 500;
            text-decoration: none;
            letter-spacing: .05em;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.15);
            background: rgba(0,0,0,.5);
            color: rgba(255,255,255,.7);
            transition: .2s;
        }
        .lang-switcher a.active, .lang-switcher a:hover {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }

        /* KATEGORİ TAB ÇUBUĞU */
        .cat-bar {
            position: sticky;
            top: 0;
            z-index: 50;
            background: rgba(13,13,13,.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
            scrollbar-width: none;
            -webkit-overflow-scrolling: touch;
        }
        .cat-bar::-webkit-scrollbar { display: none; }
        .cat-tabs {
            display: flex;
            gap: 0;
            padding: 0 1rem;
            min-width: max-content;
        }
        .cat-tab {
            padding: .9rem 1.1rem;
            font-size: .82rem;
            font-weight: 500;
            white-space: nowrap;
            color: var(--muted);
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: .2s;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: .4rem;
        }
        .cat-tab:hover { color: var(--text); }
        .cat-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

        /* ÖĞELER */
        .section { padding: 1.5rem 1rem; }
        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: #fff;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
            margin-left: .5rem;
        }

        /* FEATURED — yatay scroll */
        .featured-scroll {
            display: flex;
            gap: 1rem;
            overflow-x: auto;
            padding-bottom: .5rem;
            scrollbar-width: none;
        }
        .featured-scroll::-webkit-scrollbar { display: none; }
        .featured-card {
            flex-shrink: 0;
            width: 200px;
            background: var(--surface);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: .25s;
        }
        .featured-card:hover { transform: translateY(-3px); border-color: var(--accent); }
        .featured-card img {
            width: 100%; height: 120px; object-fit: cover;
        }
        .featured-card .fc-body { padding: .75rem; }
        .featured-card .fc-name {
            font-size: .85rem; font-weight: 600; color: #fff;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .featured-card .fc-desc {
            font-size: .72rem; color: var(--muted); margin-top: .25rem;
            overflow: hidden; text-overflow: ellipsis; display: -webkit-box;
            -webkit-line-clamp: 2; -webkit-box-orient: vertical;
        }
        .featured-card .fc-price {
            font-size: .9rem; font-weight: 700; color: var(--accent);
            margin-top: .5rem;
        }

        /* NORMAL ITEM GRID */
        .items-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: .85rem;
        }
        .item-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 18px;
            overflow: hidden;
            transition: .25s;
            display: flex;
            flex-direction: column;
        }
        .item-card:hover {
            border-color: var(--accent);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,.4);
        }
        .ic-img-wrap {
            position: relative;
            width: 100%;
            padding-top: 75%;
            background: var(--surface2);
            overflow: hidden;
        }
        .ic-img-wrap img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .35s;
        }
        .item-card:hover .ic-img-wrap img { transform: scale(1.06); }
        .ic-img-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--muted);
            font-size: 2rem;
        }
        .ic-oval-frame {
            position: absolute;
            bottom: -1px;
            left: 0; right: 0;
            height: 28px;
            background: var(--surface);
            border-radius: 50% 50% 0 0 / 100% 100% 0 0;
        }
        .ic-body {
            padding: .6rem .85rem .85rem;
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .ic-name {
            font-weight: 600;
            font-size: .88rem;
            color: #fff;
            margin-bottom: .25rem;
            line-height: 1.3;
        }
        .ic-desc {
            font-size: .72rem;
            color: var(--muted);
            line-height: 1.5;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            flex: 1;
        }
        .ic-badges { margin-top: .4rem; display: flex; gap: .25rem; flex-wrap: wrap; }
        .badge-pill {
            padding: 2px 7px; border-radius: 50px; font-size: .6rem; font-weight: 500;
            border: 1px solid;
        }
        .ic-price {
            font-family: 'Playfair Display', serif;
            font-size: 1rem;
            font-weight: 700;
            color: var(--accent);
            margin-top: .5rem;
        }

        /* DIVİDER */
        .accent-line {
            width: 40px; height: 2px;
            background: var(--accent); margin-bottom: 1.2rem;
        }

        /* Sepet fiyatı alanı yok (sadece görüntü) */
    </style>
</head>
<body>

    {{-- Dil Değiştirici --}}
